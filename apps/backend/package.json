{
  "name": "@app/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build --webpack",
    "build:docker": "nest build --config nest-cli.docker.json && tsc-alias -p tsconfig.build.json",
    "dev": "node scripts/load-env.js && yarn workspace @app/shared build && nest start --watch",
    "start": "node dist/main.js",
    "test:unit": "jest --config jest.config.ts --passWithNoTests",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.ts --runInBand --passWithNoTests",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit:coverage": "jest --config jest.config.ts --coverage --passWithNoTests",
    "typeorm": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm --dataSource src/database/database.config.ts",
    "migration:run": "yarn typeorm migration:run",
    "migration:generate": "yarn typeorm migration:generate",
    "migration:revert": "yarn typeorm migration:revert",
    "seed:run": "ts-node -r tsconfig-paths/register src/database/seeds/run-seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.600.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.2",
    "axios-retry": "^4.4.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "nest-winston": "^1.9.7",
    "opossum": "^8.1.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.2.0",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.3.10",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/opossum": "^8.1.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
