{
  "name": "@app/frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/load-env.js && next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "jest --testPathPattern='.*\\.spec\\.(ts|tsx)$' --passWithNoTests",
    "test:integration": "jest --testPathPattern='.*\\.integration\\.(ts|tsx)$' --passWithNoTests",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit:coverage": "jest --testPathPattern='.*\\.spec\\.(ts|tsx)$' --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.600.0",
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.51.21",
    "@tanstack/react-query-devtools": "^5.51.21",
    "axios": "^1.7.2",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "cypress": "^13.13.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.9",
    "ts-jest": "^29.2.3",
    "typescript": "^5.4.5"
  }
}
